rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /knockouts/{matchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /teams/{teamId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /tournament/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Username → email lookup (public read, admin-only write)
    match /admins/{username} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
