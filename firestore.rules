rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Matches (group stage) ──────────────────────────────────────────────
    match /matches/{matchId} {
      // Anyone can read fixtures
      allow read: if true;
      // Only authenticated users (admins) can write
      allow write: if request.auth != null;
    }

    // ── Knockouts ─────────────────────────────────────────────────────────
    match /knockouts/{matchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Tournament meta (future use) ───────────────────────────────────────
    match /tournament/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Block all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
